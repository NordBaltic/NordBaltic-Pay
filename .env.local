NEXT_PUBLIC_APP_URL=https://nordbalticpay.com
NEXT_PUBLIC_API_BASE_URL=https://api.nordbalticpay.com

### 🔥 NOTIFICATIONS & ANALYTICS 🔥
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_id
NEXT_PUBLIC_DISCORD_WEBHOOK=your_discord_webhook_url
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_telegram_bot_token

### 🔥 FEATURE FLAGS 🔥
FEATURE_SWAP=true
FEATURE_STAKING=true
FEATURE_DONATIONS=true
FEATURE_ADMIN_PANEL=true

### 🔥 DEBUGGING SETTINGS 🔥
DEBUG_MODE=false
LOG_LEVEL=info
